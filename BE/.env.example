PORT=3001
MONGODB_URI=mongodb+srv://user:password@host/database?authSource=admin&replicaSet=xxx&tls=true
JWT_SECRET=your-jwt-secret
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000

# MoMo — thanh toán gói SaaS (sandbox: https://developers.momo.vn)
# Bật MOMO_ENABLED=true và điền credential từ MoMo Partner Portal
MOMO_ENABLED=false
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_PARTNER_NAME=BOBAPOS
MOMO_STORE_ID=BOBAPOS
# Sandbox mặc định; production: https://payment.momo.vn/v2/gateway/api/create
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
# URL công khai BE để MoMo gọi IPN (local dev: dùng ngrok → https://xxx.ngrok.io/api/billing/momo/ipn)
MOMO_IPN_URL=
# FE sau khi thanh toán xong (polling realtime trạng hóa đơn)
MOMO_REDIRECT_URL=http://localhost:3000/dashboard/admin/billing/result
PUBLIC_API_URL=http://localhost:3001/api

# Chuyển khoản gia hạn gói SaaS (đơn giản — khuyên dùng cho EXE201)
# Đặt ảnh QR vào FE/public/billing/qr-bank.jpg hoặc đổi SAAS_BANK_QR_URL
SAAS_BANK_NAME=Techcombank
SAAS_BANK_ACCOUNT=9528677537
SAAS_BANK_HOLDER=NGUYEN HOANG MINH NHAT
SAAS_BANK_QR_URL=/billing/qr-bank.jpg
SAAS_BANK_TRANSFER_PREFIX=BOBAPOS
# SAAS_BANK_NOTE=Ghi chú thêm (tùy chọn)

# Legacy single-tenant users (teaflow-legacy)
SEED_ADMIN_EMAIL=admin@bubbletea.com
SEED_ADMIN_PASSWORD=Admin@123
SEED_ADMIN_NAME=Quản trị viên
SEED_STAFF_EMAIL=staff@bubbletea.com
SEED_STAFF_PASSWORD=Staff@123
SEED_STAFF_NAME=Nguyễn Văn Staff

# Demo tenants — mặc định tự seed (có thể ghi đè bằng env)
# SEED_DEMO_TENANTS=false
# SEED_DEMO_INVENTORY=false
SEED_DEMO_SOLO_EMAIL=demo-solo@bobapos.test
SEED_DEMO_SOLO_PASSWORD=Demo@123
SEED_DEMO_SOLO_NAME=Chủ Solo Demo
SEED_DEMO_STORE_EMAIL=demo-store@bobapos.test
SEED_DEMO_STORE_PASSWORD=Demo@123
SEED_DEMO_STORE_NAME=Chủ Store Demo
SEED_DEMO_CHAIN_EMAIL=demo-chain@bobapos.test
SEED_DEMO_CHAIN_PASSWORD=Demo@123
SEED_DEMO_CHAIN_NAME=Chủ Chain Demo
